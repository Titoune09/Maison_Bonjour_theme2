{%- comment -%} SEO — données structurées BlogPosting + fil d’Ariane {%- endcomment -%}
{%- capture article_seo_desc -%}{% if article.excerpt != blank %}{{ article.excerpt | strip_html }}{% else %}{{ article.content | strip_html | truncatewords: 40 }}{% endif %}{%- endcapture -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "mainEntityOfPage": { "@type": "WebPage", "@id": {{ canonical_url | json }} },
  "headline": {{ article.title | json }},
  "description": {{ article_seo_desc | strip_newlines | truncatewords: 50 | json }},
  {% if article.image %}"image": [{{ article.image | image_url: width: 1600 | prepend: 'https:' | json }}],{% endif %}
  "datePublished": {{ article.published_at | date: '%Y-%m-%dT%H:%M:%S%z' | json }},
  "dateModified": {{ article.updated_at | date: '%Y-%m-%dT%H:%M:%S%z' | json }},
  "author": { "@type": "{% if article.author contains 'Maison' %}Organization{% else %}Person{% endif %}", "name": {{ article.author | default: shop.name | json }} },
  "publisher": {
    "@type": "Organization",
    "name": {{ shop.name | json }},
    "logo": { "@type": "ImageObject", "url": {{ 'logo-mark.svg' | asset_url | prepend: 'https:' | json }} }
  },
  "articleSection": {{ article.tags.first | default: 'Magazine' | json }}
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": {{ shop.url | json }} },
    { "@type": "ListItem", "position": 2, "name": {{ blog.title | json }}, "item": {{ blog.url | prepend: shop.url | json }} },
    { "@type": "ListItem", "position": 3, "name": {{ article.title | json }} }
  ]
}
</script>

<article class="post" itemscope itemtype="https://schema.org/BlogPosting">
  <header class="post__header">
    <div class="post__header-inner">
      <a class="post__back" href="{{ blog.url }}">&larr; {{ blog.title | default: 'Magazine' }}</a>

      <time class="post__date" datetime="{{ article.published_at | date: '%Y-%m-%d' }}" itemprop="datePublished">
        {% render 'date-fr', date: article.published_at %}
      </time>

      <h1 class="post__title" itemprop="headline">{{ article.title }}</h1>

      {%- if article.excerpt != blank -%}
        <p class="post__lede">{{ article.excerpt | strip_html }}</p>
      {%- endif -%}

      {%- if article.author != blank -%}
        <p class="post__author" itemprop="author">— {{ article.author }}</p>
      {%- endif -%}
    </div>
  </header>

  {%- if article.image -%}
    <figure class="post__hero">
      {{ article.image | image_url: width: 2000 | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          sizes: '(min-width: 1024px) 1100px, 100vw',
          widths: '600, 900, 1200, 1600, 2000',
          class: 'post__hero-img',
          alt: article.image.alt
      }}
    </figure>
  {%- endif -%}

  <section class="post__content editorial" itemprop="articleBody">
    {{ article.content }}
  </section>

  {%- if article.tags.size > 0 -%}
    <footer class="post__footer">
      <ul class="post__tags">
        {%- for tag in article.tags -%}
          <li>{{ tag }}</li>
        {%- endfor -%}
      </ul>
    </footer>
  {%- endif -%}

  {%- if blog.next_article or blog.previous_article -%}
    <nav class="post__nav" aria-label="Navigation entre articles">
      {%- if blog.previous_article -%}
        <a class="post__nav-link" href="{{ blog.previous_article.url }}">
          <span class="post__nav-label">Précédent</span>
          <span class="post__nav-title">{{ blog.previous_article.title }}</span>
        </a>
      {%- endif -%}
      {%- if blog.next_article -%}
        <a class="post__nav-link post__nav-link--next" href="{{ blog.next_article.url }}">
          <span class="post__nav-label">Suivant</span>
          <span class="post__nav-title">{{ blog.next_article.title }}</span>
        </a>
      {%- endif -%}
    </nav>
  {%- endif -%}
</article>

<style>
  .post__header {
    padding-block: 80px 40px;
    text-align: center;
  }
  .post__header-inner {
    max-width: 760px;
    margin: 0 auto;
    padding-inline: var(--container-padding);
  }
  .post__back {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
  }
  .post__date {
    display: block;
    margin-top: 32px;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .post__title {
    margin: 16px 0 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2.25rem, 3.6vw + 1rem, 4rem);
    line-height: 1.1;
    color: var(--marine);
  }
  .post__lede {
    margin: 24px auto 0;
    max-width: 560px;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 19px;
    line-height: 1.5;
    color: var(--text-muted);
  }
  .post__author {
    margin: 20px 0 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 15px;
    color: var(--gold);
  }

  .post__hero {
    max-width: 1100px;
    margin: 40px auto;
    padding-inline: var(--container-padding);
  }
  .post__hero-img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .post__content {
    margin-top: 40px;
    padding-bottom: 100px;
  }

  /* Lettrine éditoriale sur le premier paragraphe — esprit magazine imprimé.
     Ciblée sur p:first-child uniquement : si l'article démarre par une image
     ou un titre, pas de lettrine égarée. */
  .post__content > p:first-child::first-letter {
    float: left;
    margin: 0.04em 0.12em 0 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: 3.4em;
    line-height: 0.78;
    color: var(--gold);
  }

  .post__footer {
    max-width: 720px;
    margin: 0 auto 60px;
    padding-inline: var(--container-padding);
  }
  .post__tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px 16px;
  }
  .post__tags li {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
  }
  .post__tags li::before { content: "—"; margin-right: 8px; color: var(--gold); opacity: 0.6; }

  .post__nav {
    max-width: 1100px;
    margin: 0 auto;
    padding: 48px var(--container-padding) 100px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    border-top: 1px solid var(--border);
    padding-top: 48px;
  }
  .post__nav-link {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .post__nav-link--next { text-align: right; align-items: flex-end; }
  .post__nav-label {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
  }
  .post__nav-title {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 19px;
    color: var(--marine);
  }

  @media (max-width: 767px) {
    .post__header { padding-block: 56px 24px; }
    .post__hero { margin: 24px auto; }
    .post__content { padding-bottom: 64px; }
    .post__nav {
      grid-template-columns: 1fr;
      gap: 32px;
      padding-block: 32px 64px;
    }
    .post__nav-link--next { text-align: left; align-items: flex-start; }
  }
</style>
