<script>
  (function () {
    var panels = document.querySelectorAll('[data-lang-panel]');
    var btns = document.querySelectorAll('[data-lang-btn]');
    if (!panels.length || !btns.length) return;
    function show(lang) {
      panels.forEach(function (p) { p.hidden = p.getAttribute('data-lang-panel') !== lang; });
      btns.forEach(function (b) {
        var on = b.getAttribute('data-lang-btn') === lang;
        b.classList.toggle('is-active', on);
        b.setAttribute('aria-selected', on ? 'true' : 'false');
      });
    }
    btns.forEach(function (b) {
      b.addEventListener('click', function () { show(b.getAttribute('data-lang-btn')); });
    });
  })();
</script>
