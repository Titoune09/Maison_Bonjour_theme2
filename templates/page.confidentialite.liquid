        <h2>9. Durée de conservation des données</h2>
        <div class="legal-table-wrap">
          <table class="legal-table">
            <thead><tr><th>Catégorie de données</th><th>Durée de conservation</th><th>Base</th></tr></thead>
            <tbody>
