{%- comment -%}
  Connexion client — écran premium split-screen Maison Bonjour.
  La logique Shopify (customer_login, recover_customer_password, erreurs,
  guest_login) est conservée intégralement. Le basculement « mot de passe
  oublié » se fait sans JavaScript : via CSS :target, et — quand le formulaire
  de récupération est renvoyé (succès ou erreur, sans ancre #recover dans
  l'URL) — via la classe serveur `is-recover` calculée ci-dessous.
{%- endcomment -%}

{%- comment -%} Vue « mot de passe oublié » capturée d'abord pour détecter son état serveur. {%- endcomment -%}
{%- capture recover_view -%}
  {% form 'recover_customer_password' %}
    {%- if form.posted_successfully? -%}
      {%- assign recover_open = true -%}
      <p class="mb-login__success" role="status">Si un compte existe, un e-mail vient de partir.</p>
    {%- endif -%}
    {%- if form.errors -%}
      {%- assign recover_open = true -%}
      <p class="mb-login__error" role="alert">{{ form.errors | default_errors }}</p>
    {%- endif -%}

    <div class="mb-login__field">
      <label for="RecoverEmail">E-mail</label>
      <input type="email" id="RecoverEmail" name="email" autocomplete="email" autocapitalize="off" autocorrect="off" spellcheck="false" required>
    </div>

    <button type="submit" class="mb-login__btn">Envoyer le lien</button>
  {% endform %}
{%- endcapture -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Crimson+Pro:ital,wght@0,400;0,500;1,400&family=Inter:wght@400;500&display=swap" rel="stylesheet">

<section class="mb-login{% if recover_open %} is-recover{% endif %}" aria-label="Connexion à votre compte Maison Bonjour">
  <div class="mb-login__bg" aria-hidden="true">
    <img src="{{ 'hero.jpg' | asset_url }}" alt="" width="2400" height="1600" loading="eager" fetchpriority="high">
    <span class="mb-login__bg-veil"></span>
  </div>

  <div class="mb-login__card">

    <div class="mb-login__panel mb-login__panel--form">
      <div class="mb-login__form-inner">

        <a class="mb-login__logo" href="{{ routes.root_url }}" aria-label="Maison Bonjour — Accueil">
          <img class="mb-login__logo-img"
               src="{{ 'Cartedevizitare-removebg-preview.png' | asset_url }}"
               alt="Maison Bonjour"
               width="252"
               height="144"
               loading="eager"
               decoding="async">
        </a>

        {%- comment -%} ---------- Connexion ---------- {%- endcomment -%}
        <div id="login" class="mb-login__view mb-login__view--main">
          <h1 class="mb-login__title">Retrouver mon voyage</h1>
          <p class="mb-login__lede">
            Accédez à votre abonnement, vos prochaines éditions et les traces de votre voyage français.
          </p>

          {% form 'customer_login', novalidate: 'novalidate' %}
            {%- if form.errors -%}
              <p class="mb-login__error" role="alert">{{ form.errors | default_errors }}</p>
            {%- endif -%}

            <div class="mb-login__field">
              <label for="CustomerEmail">E-mail</label>
              <input type="email" id="CustomerEmail" name="customer[email]" autocomplete="email" autocapitalize="off" autocorrect="off" spellcheck="false" required>
            </div>

            <div class="mb-login__field">
              <label for="CustomerPassword">Mot de passe</label>
              <input type="password" id="CustomerPassword" name="customer[password]" autocomplete="current-password" required>
            </div>

            <p class="mb-login__forgot">
              <a href="#recover">Mot de passe oublié</a>
            </p>

            <button type="submit" class="mb-login__btn">Se connecter</button>
          {% endform %}

          {%- if shop.checkout.guest_login -%}
            <p class="mb-login__alt">
              Première édition&nbsp;?
              <a href="{{ routes.account_register_url }}">Créer un compte</a>
            </p>
          {%- endif -%}
        </div>

        {%- comment -%} ---------- Mot de passe oublié ---------- {%- endcomment -%}
        <div id="recover" class="mb-login__view mb-login__view--recover">
          <h1 class="mb-login__title">Mot de passe oublié</h1>
          <p class="mb-login__lede">
            Entrez votre e-mail&nbsp;: nous vous envoyons un lien pour réinitialiser votre accès.
          </p>

          {{ recover_view }}

          <p class="mb-login__alt">
            <a href="#login">Retour à la connexion</a>
          </p>
        </div>

      </div>
    </div>

    <div class="mb-login__panel mb-login__panel--media">
      <img class="mb-login__media-img" src="{{ 'current-box.jpg' | asset_url }}" alt="Une édition Maison Bonjour fermée, posée sur une table en pierre claire, dans la lumière naturelle." width="1600" height="1200" loading="lazy">
      <span class="mb-login__media-veil" aria-hidden="true"></span>
      <div class="mb-login__editorial">
        <p class="mb-login__quote">Chaque édition laisse une trace.</p>
        <p class="mb-login__quote-sub">
          Retrouvez vos régions reçues, vos prochaines éditions et les départs Maison Bonjour à venir.
        </p>
      </div>
    </div>

  </div>
</section>

<style>
  .mb-login {
    --c-cream:    #F5F0E8;
    --c-cream-2:  #EDE5D4;
    --c-marine:   #1C2B4A;
    --c-deep:     #0F1A2E;
    --c-gold:     #B8965A;
    --c-brown:    #5A4E3A;
    --serif: 'Playfair Display', Georgia, serif;
    --body:  'Crimson Pro', Georgia, serif;
    --ui:    'Inter', system-ui, sans-serif;

    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: grid;
    place-items: center;
    padding: clamp(72px, 10vh, 120px) 16px clamp(40px, 6vh, 72px);
    isolation: isolate;
    overflow: hidden;
  }

  /* Fond immersif global */
  .mb-login__bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }
  .mb-login__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: saturate(0.82) brightness(0.7);
  }
  .mb-login__bg-veil {
    position: absolute;
    inset: 0;
    background: var(--c-deep);
    opacity: 0.45;
  }

  /* Bloc central rectangulaire */
  .mb-login__card {
    width: clamp(320px, 84vw, 1280px);
    min-height: min(74vh, 760px);
    display: grid;
    grid-template-columns: 38% 62%;
    background: var(--c-cream);
    box-shadow: 0 24px 60px -32px rgba(15, 26, 46, 0.5);
    overflow: hidden;
  }

  .mb-login__panel { position: relative; }

  /* Colonne formulaire */
  .mb-login__panel--form {
    background: var(--c-cream);
    display: flex;
    align-items: center;
  }
  .mb-login__form-inner {
    width: 100%;
    padding: clamp(40px, 4.5vw, 72px);
  }

  .mb-login__logo {
    display: block;
    margin-bottom: clamp(28px, 5vh, 48px);
    line-height: 0;
    transition: opacity 0.25s ease;
  }
  .mb-login__logo:hover { opacity: 0.85; }
  .mb-login__logo-img {
    display: block;
    width: auto;
    height: auto;
    max-height: 110px;
    max-width: 100%;
  }

  /* Bascule connexion / récupération sans JS.
     - :target  → clic sur « Mot de passe oublié »
     - .is-recover → renvoi serveur du formulaire (succès / erreur) */
  .mb-login__view--recover { display: none; }
  .mb-login:has(#recover:target) .mb-login__view--main,
  .mb-login.is-recover:not(:has(#login:target)) .mb-login__view--main { display: none; }
  .mb-login:has(#recover:target) .mb-login__view--recover,
  .mb-login.is-recover:not(:has(#login:target)) .mb-login__view--recover { display: block; }

  .mb-login__title {
    margin: 0 0 16px;
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(1.9rem, 1.4vw + 1.4rem, 2.6rem);
    line-height: 1.08;
    color: var(--c-marine);
  }
  .mb-login__lede {
    margin: 0 0 clamp(28px, 4vh, 40px);
    max-width: 38ch;
    font-family: var(--body);
    font-size: 17px;
    line-height: 1.5;
    color: var(--c-brown);
  }

  .mb-login__field {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 22px;
  }
  .mb-login__field label {
    font-family: var(--ui);
    font-weight: 500;
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--c-brown);
  }
  .mb-login__field input {
    width: 100%;
    background: transparent;
    border: 1px solid rgba(90, 78, 58, 0.3);
    border-radius: 0;
    padding: 13px 14px;
    font-family: var(--body);
    font-size: 17px;
    color: var(--c-marine);
    transition: border-color 0.2s ease;
    -webkit-appearance: none;
    appearance: none;
  }
  .mb-login__field input::placeholder { color: rgba(90, 78, 58, 0.5); }
  .mb-login__field input:focus {
    outline: none;
    border-color: var(--c-gold);
    box-shadow: 0 0 0 1px var(--c-gold);
  }

  .mb-login__forgot {
    margin: -6px 0 26px;
    text-align: right;
  }
  .mb-login__forgot a {
    font-family: var(--ui);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--c-brown);
    text-decoration: none;
    border-bottom: 1px solid rgba(90, 78, 58, 0.35);
    padding-bottom: 1px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .mb-login__forgot a:hover {
    color: var(--c-gold);
    border-color: var(--c-gold);
  }

  .mb-login__btn {
    width: 100%;
    border: 0;
    border-radius: 0;
    padding: 15px 24px;
    background: var(--c-marine);
    color: var(--c-cream);
    font-family: var(--ui);
    font-weight: 500;
    font-size: 12px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }
  .mb-login__btn:hover { background: var(--c-deep); }
  .mb-login__btn:focus-visible {
    outline: 2px solid var(--c-gold);
    outline-offset: 2px;
  }

  .mb-login__alt {
    margin: 24px 0 0;
    font-family: var(--body);
    font-size: 16px;
    color: var(--c-brown);
  }
  .mb-login__alt a {
    color: var(--c-marine);
    font-family: var(--ui);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    border-bottom: 1px solid var(--c-gold);
    padding-bottom: 1px;
    margin-left: 4px;
  }
  .mb-login__alt a:hover { color: var(--c-gold); }

  .mb-login__error,
  .mb-login__success {
    margin: 0 0 24px;
    padding: 12px 16px;
    font-family: var(--body);
    font-size: 15px;
    line-height: 1.4;
  }
  .mb-login__error {
    border: 1px solid #8B2E2E;
    color: #8B2E2E;
    background: rgba(139, 46, 46, 0.05);
  }
  .mb-login__success {
    border: 1px solid var(--c-gold);
    color: var(--c-brown);
    background: rgba(184, 150, 90, 0.08);
    font-style: italic;
  }

  /* Colonne média */
  .mb-login__panel--media {
    background: var(--c-cream-2);
    overflow: hidden;
  }
  .mb-login__media-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: saturate(0.9);
  }
  .mb-login__media-veil {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(15, 26, 46, 0.05) 0%, rgba(15, 26, 46, 0.55) 100%);
  }
  .mb-login__editorial {
    position: absolute;
    left: clamp(32px, 4vw, 64px);
    right: clamp(32px, 4vw, 64px);
    bottom: clamp(36px, 6vh, 64px);
  }
  .mb-login__quote {
    margin: 0 0 14px;
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.7rem, 1.4vw + 1.2rem, 2.4rem);
    line-height: 1.12;
    color: var(--c-cream);
  }
  .mb-login__quote-sub {
    margin: 0;
    max-width: 44ch;
    font-family: var(--body);
    font-size: 17px;
    line-height: 1.5;
    color: rgba(245, 240, 232, 0.82);
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 900px) {
    .mb-login {
      padding: 0;
      align-items: stretch;
    }
    .mb-login__bg { display: none; }
    .mb-login__card {
      width: 100%;
      min-height: 100vh;
      min-height: 100svh;
      grid-template-columns: 1fr;
      grid-template-rows: minmax(32vh, 38vh) 1fr;
      box-shadow: none;
    }
    .mb-login__panel--media { order: -1; }
    .mb-login__editorial {
      left: clamp(28px, 7vw, 32px);
      right: clamp(28px, 7vw, 32px);
      bottom: clamp(24px, 4vh, 32px);
    }
    .mb-login__quote { font-size: clamp(1.5rem, 4vw + 0.6rem, 2rem); }
    .mb-login__quote-sub { font-size: 15px; }
    .mb-login__form-inner { padding: clamp(28px, 7vw, 32px); }
    .mb-login__logo { margin-bottom: 24px; }
    .mb-login__forgot { text-align: left; }
  }

  @media (prefers-reduced-motion: reduce) {
    .mb-login__field input,
    .mb-login__btn,
    .mb-login__forgot a,
    .mb-login__alt a { transition: none; }
  }
</style>
