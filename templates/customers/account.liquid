<article class="account">
  <div class="account__shell account__shell--wide">
    <header class="account__header">
      <span class="label">Mon compte</span>
      <h1 class="account__title">{{ customer.name | default: customer.email }}</h1>
      <hr class="sep sep--center">
      <p class="account__links" style="justify-content:center;">
        <a href="{{ routes.account_logout_url }}">Se déconnecter</a>
      </p>
    </header>

    <section class="account-section">
      <h2 class="account-section__title">Historique des commandes</h2>

      {%- if customer.orders.size > 0 -%}
        {%- paginate customer.orders by 20 -%}
          <table class="account-orders">
            <thead>
              <tr>
                <th scope="col">Commande</th>
                <th scope="col">Date</th>
                <th scope="col">Paiement</th>
                <th scope="col">Livraison</th>
                <th scope="col">Total</th>
              </tr>
            </thead>
            <tbody>
              {%- for order in customer.orders -%}
                <tr>
                  <td><a href="{{ order.customer_url }}">{{ order.name }}</a></td>
                  <td>{% render 'date-fr', date: order.created_at %}</td>
                  <td>{{ order.financial_status_label }}</td>
                  <td>{{ order.fulfillment_status_label }}</td>
                  <td>{{ order.total_price | money }}</td>
                </tr>
              {%- endfor -%}
            </tbody>
          </table>

          {%- if paginate.pages > 1 -%}
            <nav class="collection__pagination" aria-label="Pagination">
              {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}">&larr; Précédent</a>{%- endif -%}
              <span>Page {{ paginate.current_page }} / {{ paginate.pages }}</span>
              {%- if paginate.next -%}<a href="{{ paginate.next.url }}">Suivant &rarr;</a>{%- endif -%}
            </nav>
          {%- endif -%}
        {%- endpaginate -%}
      {%- else -%}
        <p class="account__hint">Aucune commande pour le moment.</p>
      {%- endif -%}
    </section>

    <section class="account-section">
      <h2 class="account-section__title">Mes coordonnées</h2>

      {%- if customer.default_address -%}
        <div class="account-address">
          <p class="account-address__name">{{ customer.default_address.first_name }} {{ customer.default_address.last_name }}</p>
          <div class="account-address__body">
            {{ customer.default_address | format_address }}
          </div>
          <p class="account-address__actions">
            <a href="{{ routes.account_addresses_url }}">Voir / modifier toutes mes adresses</a>
          </p>
        </div>
      {%- else -%}
        <p class="account__hint">Aucune adresse enregistrée.</p>
        <p class="account__links" style="margin-top:16px;">
          <a href="{{ routes.account_addresses_url }}">Ajouter une adresse</a>
        </p>
      {%- endif -%}
    </section>
  </div>
</article>

{% render 'account-styles' %}
