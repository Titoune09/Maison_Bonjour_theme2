{%- liquid
  assign current_variant = product.selected_or_first_available_variant
-%}

<article class="product" itemscope itemtype="https://schema.org/Product">
  <meta itemprop="name" content="{{ product.title | escape }}">
  <meta itemprop="description" content="{{ product.description | strip_html | escape }}">

  <div class="product__wrap">
    <div class="product__gallery">
      {%- if product.images.size > 0 -%}
        <div class="product__main paper-panel">
          {{ product.featured_image | image_url: width: 1600 | image_tag:
              loading: 'eager',
              fetchpriority: 'high',
              sizes: '(min-width: 1024px) 50vw, 100vw',
              widths: '600, 900, 1200, 1600',
              class: 'product__img',
              alt: product.featured_image.alt
          }}
        </div>
        {%- if product.images.size > 1 -%}
          <ul class="product__thumbs" role="list">
            {%- for image in product.images -%}
              <li>
                <button
                  type="button"
                  class="product__thumb{% if forloop.first %} is-active{% endif %}"
                  data-product-thumb="{{ image | image_url: width: 1600 }}"
                  data-product-alt="{{ image.alt | escape }}"
                  aria-label="Voir l'image {{ forloop.index }}">
                  {{ image | image_url: width: 400 | image_tag:
                      loading: 'lazy',
                      sizes: '120px',
                      widths: '200, 400',
                      class: 'product__thumb-img',
                      alt: image.alt
                  }}
                </button>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      {%- else -%}
        <div class="product__main product__main--placeholder" aria-hidden="true"></div>
      {%- endif -%}
    </div>

    <div class="product__info">
      <span class="ticket-label product__edition">Sélection Maison Bonjour</span>
      {%- if product.vendor != blank -%}
        <span class="label">{{ product.vendor }}</span>
      {%- endif -%}

      <h1 class="product__title">{{ product.title }}</h1>

      <p class="product__price" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
        <meta itemprop="priceCurrency" content="{{ cart.currency.iso_code }}">
        <meta itemprop="price" content="{{ current_variant.price | divided_by: 100.0 }}">
        <span class="product__price-amount">{{ current_variant.price | money }}</span>
        {%- if current_variant.compare_at_price > current_variant.price -%}
          <span class="product__price-compare">{{ current_variant.compare_at_price | money }}</span>
        {%- endif -%}
      </p>

      <hr class="sep">

      {%- if product.description != blank -%}
        <div class="product__desc">{{ product.description }}</div>
      {%- endif -%}

      <form action="{{ routes.cart_add_url }}" method="post" enctype="multipart/form-data" class="product__form paper-panel">
        {%- unless product.has_only_default_variant -%}
          <div class="product__variants">
            {%- for option in product.options_with_values -%}
              <div class="product__option">
                <label for="option-{{ forloop.index0 }}">{{ option.name }}</label>
                <select name="options[{{ option.name | escape }}]" id="option-{{ forloop.index0 }}">
                  {%- for value in option.values -%}
                    <option value="{{ value | escape }}"{% if option.selected_value == value %} selected{% endif %}>{{ value }}</option>
                  {%- endfor -%}
                </select>
              </div>
            {%- endfor -%}
          </div>
        {%- endunless -%}

        <input type="hidden" name="id" value="{{ current_variant.id }}">

        <div class="product__qty">
          <label for="quantity">Quantité</label>
          <input type="number" name="quantity" id="quantity" value="1" min="1" inputmode="numeric">
        </div>

        <button
          type="submit"
          class="btn btn--primary product__btn"
          {% unless current_variant.available %}disabled{% endunless %}>
          {%- if current_variant.available -%}
            Ajouter au panier
          {%- else -%}
            Épuisé
          {%- endif -%}
        </button>
      </form>
    </div>
  </div>
</article>

<style>
  .product__wrap {
    max-width: 1240px;
    margin: 0 auto;
    padding: 80px var(--container-padding) 120px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
  }
  .product__main {
    width: 100%;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    padding: 10px;
  }
  .product__main--placeholder { background: var(--cream-warm); }
  .product__img { width: 100%; height: 100%; object-fit: cover; }

  .product__thumbs {
    list-style: none;
    padding: 0;
    margin: 16px 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .product__thumb {
    display: block;
    padding: 0;
    border: 1px solid transparent;
    background: transparent;
    transition: border-color 0.25s ease, transform 0.25s var(--ease-out);
  }
  .product__thumb.is-active {
    border-color: var(--gold);
  }
  .product__thumb:hover { transform: translateY(-2px); }
  .product__thumb-img {
    width: 80px;
    aspect-ratio: 1;
    object-fit: cover;
  }
  .product__img {
    transition: opacity 0.18s ease, transform 0.7s var(--ease-out);
  }
  .product__img.is-swapping {
    opacity: 0;
    transform: scale(0.985);
  }

  .product__edition {
    margin-bottom: 16px;
  }

  .product__title {
    margin: 16px 0 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2rem, 3vw + 1rem, 3rem);
    line-height: 1.1;
    color: var(--marine);
  }
  .product__price {
    margin: 24px 0 0;
    display: flex;
    align-items: baseline;
    gap: 12px;
  }
  .product__price-amount {
    font-family: var(--font-serif);
    font-size: 32px;
    color: var(--marine);
  }
  .product__price-compare {
    font-family: var(--font-sans);
    font-size: 16px;
    color: var(--text-muted);
    text-decoration: line-through;
  }

  .product__desc {
    margin-top: 32px;
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 16px;
    line-height: 1.75;
    color: var(--text);
    max-width: 540px;
  }
  .product__desc p + p { margin-top: 1em; }

  .product__form {
    margin-top: 40px;
    padding: 28px;
  }
  .product__variants {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 24px;
  }
  .product__option label,
  .product__qty label {
    display: block;
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 6px;
  }
  .product__option select,
  .product__qty input {
    background: transparent;
    border: 1px solid var(--border);
    padding: 12px 16px;
    font-family: var(--font-sans);
    font-size: 15px;
    color: var(--text);
    border-radius: 0;
    width: 100%;
    max-width: 280px;
  }
  .product__option select:focus,
  .product__qty input:focus { outline: none; border-color: var(--gold); }

  .product__qty { margin-top: 16px; }
  .product__qty input { max-width: 100px; }

  .product__btn { margin-top: 32px; }
  .product__btn[disabled] { opacity: 0.5; cursor: not-allowed; }

  @media (min-width: 1024px) {
    .product__wrap {
      grid-template-columns: 6fr 5fr;
      gap: 80px;
    }
  }
  @media (max-width: 767px) {
    .product__wrap { padding-block: 32px 64px; gap: 32px; }
  }
</style>
