<!doctype html>
<html lang="{{ request.locale.iso_code | default: 'fr' }}" class="no-js">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="theme-color" content="#FEF9F3">
  <meta name="format-detection" content="telephone=no">

  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- else -%}
    <link rel="icon" type="image/svg+xml" href="{{ 'favicon.svg' | asset_url }}">
    <link rel="icon" type="image/png" sizes="32x32" href="{{ 'favicon.png' | asset_url }}">
    <link rel="icon" type="image/png" sizes="16x16" href="{{ 'favicon-16.png' | asset_url }}">
  {%- endif -%}
  <link rel="apple-touch-icon" sizes="180x180" href="{{ 'apple-touch.png' | asset_url }}">
  <link rel="mask-icon" href="{{ 'logo-mark.svg' | asset_url }}" color="#1B2A41">

  <link rel="canonical" href="{{ canonical_url }}">

  <title>
    {%- if template.name == 'index' -%}
      {{ shop.name }} &mdash; L&rsquo;art de vivre fran&ccedil;ais, livr&eacute; chaque mois &agrave; Cluj-Napoca
    {%- else -%}
      {{ page_title }}
      {%- if current_tags %} &ndash; {{ current_tags | join: ', ' }}{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    {%- endif -%}
  </title>

  {%- if page_description -%}
    <meta name="description" content="{{ page_description | escape }}">
  {%- else -%}
    <meta name="description" content="Maison Bonjour. L&rsquo;art de vivre fran&ccedil;ais, livr&eacute; chaque mois &agrave; Cluj-Napoca. Une box mensuelle compos&eacute;e d&rsquo;objets et produits choisis chez des artisans fran&ccedil;ais.">
  {%- endif -%}

  <meta property="og:site_name" content="{{ shop.name }}">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:title" content="{{ page_title | escape }}">
  <meta property="og:type" content="{% if template.name == 'product' %}product{% elsif template.name == 'article' %}article{% else %}website{% endif %}">
  <meta property="og:locale" content="{{ request.locale.iso_code | default: 'fr_FR' }}">
  {%- if page_description -%}
    <meta property="og:description" content="{{ page_description | escape }}">
  {%- endif -%}
  {%- if page_image -%}
    <meta property="og:image" content="https:{{ page_image | image_url: width: 1200 }}">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
  {%- else -%}
    <meta property="og:image" content="{{ 'og-image.jpg' | asset_url }}">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
  {%- endif -%}
  <meta name="twitter:card" content="summary_large_image">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@300;400;500&family=Playfair+Display:ital,wght@0,400;0,500;1,400&family=Crimson+Pro:ital,wght@0,400;1,400&family=Angkor&family=Kalnia:wght@100..700&family=New+Rocker&family=Notable&family=Parisienne&display=swap" rel="stylesheet">

  {{ 'base.css' | asset_url | stylesheet_tag }}

  <script>
    (function () {
      var d = document.documentElement;
      d.classList.remove('no-js');
      d.classList.add('js');
      if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        d.classList.add('reduced-motion');
      }
    })();
  </script>

  {{ content_for_header }}
</head>

<body class="template-{{ template | replace: '.', '-' | handle }}{% if customer %} customer-logged-in{% endif %}">
  <a class="skip-link visually-hidden" href="#MainContent">Aller au contenu</a>

  <div class="scroll-progress" aria-hidden="true">
    <div class="scroll-progress__bar" data-mb-scroll-progress></div>
  </div>


  {% section 'header' %}

  <main id="MainContent" class="main" role="main">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  <div class="grain" aria-hidden="true"></div>

  <script src="https://unpkg.com/lenis@1.1.13/dist/lenis.min.js" defer></script>
  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</body>
</html>
