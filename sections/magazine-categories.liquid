{%- liquid
  assign heading  = section.settings.heading | default: 'Le sommaire'
  assign title    = section.settings.title | default: 'Ce que raconte le Magazine.'
  assign subtext  = section.settings.subtext | default: 'D’une région française à un objet de table, d’un artisan à un rituel du matin — chaque sujet prolonge l’expérience de la box.'

  # Blog source : réglage explicite, sinon on retombe sur le blog « magazine » puis « news », puis le premier blog avec articles.
  assign mag_blog = blogs[section.settings.blog]
  if mag_blog == blank or mag_blog.articles_count == 0
    assign mag_blog = blogs['magazine']
  endif
  if mag_blog == blank or mag_blog.articles_count == 0
    assign mag_blog = blogs['news']
  endif
  if mag_blog == blank or mag_blog.articles_count == 0
    for b in blogs
      if b.articles_count > 0
        assign mag_blog = b
        break
      endif
    endfor
  endif

  # Static include: no preset blocks arrive, so fall back to default categories.
  assign d_tabs   = 'Régions,Artisans,Table,Beauté,Objets,Carnets' | split: ','
  assign d_tags   = 'regions,artisans,table,beaute,objets,carnets' | split: ','
  assign d_titles = 'Régions françaises~Maisons & artisans~Arts de la table~Beauté & parfums~Objets choisis~Carnets de voyage' | split: '~'
  assign d_texts  = 'Des Alpilles au Pays basque, chaque édition commence par un territoire. Le Magazine en garde la trace.~Un nom, un atelier, un savoir-faire. On remonte jusqu’à la main qui fabrique.~Céramique, linge, épicerie fine : la France se reçoit d’abord à table.~Des rituels simples, des matières nobles, des parfums de saison.~Ce qu’on garde, ce qu’on transmet, ce qui dure plus qu’une mode.~Des notes prises en chemin, entre un marché et une route de campagne.' | split: '~'
  assign d_imgs   = 'magazine-cat-regions.jpg,magazine-cat-artisans.jpg,magazine-cat-table.jpg,magazine-cat-beaute.jpg,paysage-region-val-de-loire-01.jpeg,paysage-region-cote-d-azur-01.jpeg' | split: ','
-%}

<section class="mb-rev-cats band--paper" aria-label="Catégories éditoriales" data-mb-categories="{{ section.id }}">
  <div class="wrap">
    <header class="mb-rev-cats__head reveal">
      <span class="mb-magazine__folio">04</span>
      <span class="label label--marker">{{ heading }}</span>
      <h2 class="mb-rev-cats__heading">{{ title }}</h2>
      {%- if subtext != blank -%}
        <p class="mb-rev-cats__sub">{{ subtext }}</p>
      {%- endif -%}
    </header>
    <hr class="mb-magazine__rule mb-magazine__rule--gold">

    <div class="mb-rev-cats__grid">
      <ul class="mb-rev-cats__tabs" role="tablist" aria-orientation="vertical">
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            <li role="presentation">
              <button type="button"
                      class="mb-rev-cats__tab{% if forloop.first %} is-active{% endif %}"
                      role="tab"
                      id="cat-tab-{{ section.id }}-{{ forloop.index }}"
                      aria-controls="cat-panel-{{ section.id }}-{{ forloop.index }}"
                      aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                      data-cat-tab="{{ forloop.index }}"
                      {{ block.shopify_attributes }}>
                <span class="mb-rev-cats__tab-num">{{ forloop.index | prepend: '0' }}</span>
                <span class="mb-rev-cats__tab-label">{{ block.settings.tab_label | default: block.settings.title }}</span>
              </button>
            </li>
          {%- endfor -%}
        {%- else -%}
          {%- for label in d_tabs -%}
            <li role="presentation">
              <button type="button"
                      class="mb-rev-cats__tab{% if forloop.first %} is-active{% endif %}"
                      role="tab"
                      id="cat-tab-{{ section.id }}-{{ forloop.index }}"
                      aria-controls="cat-panel-{{ section.id }}-{{ forloop.index }}"
                      aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                      data-cat-tab="{{ forloop.index }}">
                <span class="mb-rev-cats__tab-num">{{ forloop.index | prepend: '0' }}</span>
                <span class="mb-rev-cats__tab-label">{{ label }}</span>
              </button>
            </li>
          {%- endfor -%}
        {%- endif -%}
      </ul>

      <div class="mb-rev-cats__panels">
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            {%- liquid
              assign cat_alt = block.settings.image.alt | default: block.settings.title
              assign cat_link = block.settings.link_url
              if cat_link == blank and block.settings.tag != blank and mag_blog != blank
                assign cat_link = mag_blog.url | append: '/tagged/' | append: block.settings.tag
              endif
              if cat_link == blank
                assign cat_link = '#mb-magazine-latest'
              endif
              assign cat_cta = block.settings.link_label | default: 'Explorer les articles'
            -%}
            <div class="mb-rev-cats__panel"
                 role="tabpanel"
                 id="cat-panel-{{ section.id }}-{{ forloop.index }}"
                 aria-labelledby="cat-tab-{{ section.id }}-{{ forloop.index }}"
                 data-cat-panel="{{ forloop.index }}"
                 {% unless forloop.first %}hidden{% endunless %}
                 {{ block.shopify_attributes }}>
              <figure class="mb-rev-cats__media">
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 1000 | image_tag:
                      loading: 'lazy', sizes: '(min-width: 980px) 42vw, 100vw',
                      widths: '500, 700, 1000', class: 'mb-rev-cats__img',
                      alt: cat_alt }}
                {%- else -%}
                  <img src="{{ 'paysage-region-provence-04.jpeg' | asset_url }}"
                       alt="{{ block.settings.title }}" class="mb-rev-cats__img"
                       width="700" height="900" loading="lazy">
                {%- endif -%}
              </figure>
              <div class="mb-rev-cats__text">
                <h3 class="mb-rev-cats__title">{{ block.settings.title }}</h3>
                <p class="mb-rev-cats__body">{{ block.settings.text }}</p>
                <a href="{{ cat_link }}" class="mb-magazine__readlink">{{ cat_cta }} <span aria-hidden="true">&rarr;</span></a>
              </div>
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- for label in d_tabs -%}
            <div class="mb-rev-cats__panel"
                 role="tabpanel"
                 id="cat-panel-{{ section.id }}-{{ forloop.index }}"
                 aria-labelledby="cat-tab-{{ section.id }}-{{ forloop.index }}"
                 data-cat-panel="{{ forloop.index }}"
                 {% unless forloop.first %}hidden{% endunless %}>
              <figure class="mb-rev-cats__media">
                <img src="{{ d_imgs[forloop.index0] | asset_url }}"
                     alt="{{ d_titles[forloop.index0] }}" class="mb-rev-cats__img"
                     width="700" height="900" loading="lazy">
              </figure>
              <div class="mb-rev-cats__text">
                <h3 class="mb-rev-cats__title">{{ d_titles[forloop.index0] }}</h3>
                <p class="mb-rev-cats__body">{{ d_texts[forloop.index0] }}</p>
                {%- liquid
                  assign d_link = '#mb-magazine-latest'
                  if mag_blog != blank
                    assign d_link = mag_blog.url | append: '/tagged/' | append: d_tags[forloop.index0]
                  endif
                -%}
                <a href="{{ d_link }}" class="mb-magazine__readlink">Explorer les articles <span aria-hidden="true">&rarr;</span></a>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    var root = document.querySelector('[data-mb-categories="{{ section.id }}"]');
    if (!root) return;
    var tabs = Array.prototype.slice.call(root.querySelectorAll('[data-cat-tab]'));
    var panels = root.querySelectorAll('[data-cat-panel]');
    function activate(id, setFocus) {
      tabs.forEach(function (t) {
        var on = t.getAttribute('data-cat-tab') === id;
        t.classList.toggle('is-active', on);
        t.setAttribute('aria-selected', on ? 'true' : 'false');
        t.tabIndex = on ? 0 : -1;
        if (on && setFocus) { t.focus(); }
      });
      panels.forEach(function (p) {
        p.hidden = p.getAttribute('data-cat-panel') !== id;
      });
    }
    tabs.forEach(function (t, i) { t.tabIndex = i === 0 ? 0 : -1; });
    tabs.forEach(function (t, i) {
      t.addEventListener('click', function () { activate(t.getAttribute('data-cat-tab')); });
      t.addEventListener('keydown', function (e) {
        var next;
        if (e.key === 'ArrowRight' || e.key === 'ArrowDown') { next = (i + 1) % tabs.length; }
        else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') { next = (i - 1 + tabs.length) % tabs.length; }
        else if (e.key === 'Home') { next = 0; }
        else if (e.key === 'End') { next = tabs.length - 1; }
        else { return; }
        e.preventDefault();
        activate(tabs[next].getAttribute('data-cat-tab'), true);
      });
    });
  })();
</script>

{% stylesheet %}
  .mb-rev-cats { padding-block: clamp(64px, 8vw, 120px); }

  .mb-rev-cats__head { max-width: 760px; }
  .mb-rev-cats__head .mb-magazine__folio { display: block; }
  .mb-rev-cats__head .label--marker {
    margin-top: 14px;
    font-family: var(--font-sans);
    font-size: 11px; font-weight: 500;
    letter-spacing: 0.28em; text-transform: uppercase;
    color: var(--marine);
  }
  .mb-rev-cats__heading {
    margin: 16px 0 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2.2rem, 3.4vw + 1rem, 4rem);
    line-height: 1.05;
    color: var(--marine);
  }
  .mb-rev-cats__sub {
    margin: 18px 0 28px;
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 17px;
    line-height: 1.7;
    color: var(--text-muted);
    max-width: 56ch;
  }

  .mb-rev-cats__grid {
    margin-top: clamp(36px, 5vw, 56px);
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  /* Numbered editorial index (tabs) */
  .mb-rev-cats__tabs { list-style: none; margin: 0; padding: 0; }
  .mb-rev-cats__tab {
    display: flex;
    align-items: baseline;
    gap: 16px;
    width: 100%;
    text-align: left;
    background: none;
    border: 0;
    border-top: 1px solid var(--border);
    padding: 18px 6px;
    cursor: pointer;
    color: var(--marine);
    transition: padding-left 0.3s cubic-bezier(0.22,1,0.36,1), color 0.25s ease;
  }
  .mb-rev-cats__tabs li:last-child .mb-rev-cats__tab { border-bottom: 1px solid var(--border); }
  .mb-rev-cats__tab-num {
    font-family: var(--font-sans);
    font-size: 11px; font-weight: 500;
    letter-spacing: 0.2em;
    color: var(--gold);
    padding-top: 6px;
  }
  .mb-rev-cats__tab-label {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.4rem, 2vw, 1.9rem);
    line-height: 1.1;
    color: inherit;
  }
  .mb-rev-cats__tab:hover { padding-left: 14px; }
  .mb-rev-cats__tab.is-active { padding-left: 14px; color: var(--gold); }
  .mb-rev-cats__tab.is-active .mb-rev-cats__tab-num { color: var(--marine); }

  .mb-rev-cats__panel[hidden] { display: none !important; }

  .mb-rev-cats__media { margin: 0; overflow: hidden; }
  .mb-rev-cats__img { width: 100%; aspect-ratio: 4 / 5; object-fit: cover; display: block; }
  .mb-rev-cats__title {
    margin: 22px 0 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.8rem, 2.6vw, 2.6rem);
    color: var(--marine);
  }
  .mb-rev-cats__body {
    margin: 16px 0 24px;
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 16px;
    line-height: 1.72;
    color: var(--text-muted);
  }

  @media (min-width: 980px) {
    .mb-rev-cats__grid { grid-template-columns: 0.9fr 1.4fr; gap: 64px; align-items: start; }
    .mb-rev-cats__panel { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Magazine — 04 Catégories",
  "settings": [
    { "type": "text", "id": "heading", "label": "Label (au-dessus du titre)", "default": "Le sommaire" },
    { "type": "text", "id": "title", "label": "Titre", "default": "Ce que raconte le Magazine." },
    { "type": "textarea", "id": "subtext", "label": "Sous-texte", "default": "D’une région française à un objet de table, d’un artisan à un rituel du matin — chaque sujet prolonge l’expérience de la box." },
    { "type": "blog", "id": "blog", "label": "Blog source", "info": "Laisser vide pour utiliser le blog « magazine » par défaut." }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Catégorie",
      "limit": 8,
      "settings": [
        { "type": "text", "id": "tab_label", "label": "Libellé de l’onglet (court)" },
        { "type": "text", "id": "title", "label": "Titre" },
        { "type": "textarea", "id": "text", "label": "Texte" },
        { "type": "image_picker", "id": "image", "label": "Image (portrait 4/5)" },
        { "type": "text", "id": "tag", "label": "Tag du blog (ex. regions)", "info": "Filtre le blog par ce tag : /blogs/magazine/tagged/<tag>." },
        { "type": "text", "id": "link_label", "label": "Libellé du lien", "default": "Explorer les articles" },
        { "type": "url", "id": "link_url", "label": "URL (prioritaire sur le tag)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Magazine — 04 Catégories",
      "blocks": [
        { "type": "category", "settings": { "tab_label": "Régions", "title": "Régions françaises", "tag": "regions", "text": "Des Alpilles au Pays basque, chaque édition commence par un territoire. Le Magazine en garde la trace." } },
        { "type": "category", "settings": { "tab_label": "Artisans", "title": "Maisons & artisans", "tag": "artisans", "text": "Un nom, un atelier, un savoir-faire. On remonte jusqu’à la main qui fabrique." } },
        { "type": "category", "settings": { "tab_label": "Table", "title": "Arts de la table", "tag": "table", "text": "Céramique, linge, épicerie fine : la France se reçoit d’abord à table." } },
        { "type": "category", "settings": { "tab_label": "Beauté", "title": "Beauté & parfums", "tag": "beaute", "text": "Des rituels simples, des matières nobles, des parfums de saison." } },
        { "type": "category", "settings": { "tab_label": "Objets", "title": "Objets choisis", "tag": "objets", "text": "Ce qu’on garde, ce qu’on transmet, ce qui dure plus qu’une mode." } },
        { "type": "category", "settings": { "tab_label": "Carnets", "title": "Carnets de voyage", "tag": "carnets", "text": "Des notes prises en chemin, entre un marché et une route de campagne." } }
      ]
    }
  ]
}
{% endschema %}
