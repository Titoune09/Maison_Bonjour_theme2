      "limit": 3,
      "settings": [
        { "type": "text",     "id": "number", "label": "Numéro", "default": "01" },
        { "type": "text",     "id": "label",  "label": "Label (majuscules)" },
        { "type": "text",     "id": "title",  "label": "Titre court" },
