            "text": "Pierre sélectionne les maisons, Tiffany compose l’expérience. Chaque box suit une région française.",
            "icon_type": "calendar"
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "03",
            "label": "RECEVOIR",
            "title": "Une parenthèse française à la maison.",
            "text": "La box arrive chez toi en Roumanie, avec ses objets, ses goûts et son livret éditorial.",
            "icon_type": "hand"
          }
        }
      ]
    }
  ]
}
