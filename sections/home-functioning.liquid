        {
          "type": "select",
          "id": "icon_type",
          "label": "Illustration",
          "options": [
            { "value": "envelope", "label": "Enveloppe" },
            { "value": "calendar", "label": "Calendrier" },
            { "value": "hand",     "label": "Main / coffret" }
          ],
          "default": "envelope"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "08 — Fonctionnement",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "number": "01",
            "label": "CHOISIR",
            "title": "La formule qui te ressemble.",
            "text": "Mensuelle, trois mois ou le Grand Tour Français. Tu choisis ton rythme, sans pression inutile.",
            "icon_type": "envelope"
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "02",
            "label": "ATTENDRE",
