{%- liquid
  assign b2b_url        = section.settings.b2b_url
  assign subscribe_url  = section.settings.subscribe_url
  assign faq_url        = section.settings.faq_url | default: '/pages/faq'
  assign contact_url    = section.settings.contact_url | default: '/pages/contact'
  assign cgv_url        = section.settings.cgv_url | default: '/pages/cgv'
  assign privacy_url    = section.settings.privacy_url | default: '/pages/confidentialite'
  assign magazine_url   = section.settings.magazine_url

  assign instagram_url  = section.settings.instagram_url
  assign tiktok_url     = section.settings.tiktok_url
  assign facebook_url   = section.settings.facebook_url

  assign year = 'now' | date: '%Y'
-%}

<aside class="mb-b2b" aria-label="Cadeaux et commandes entreprise">
  <div class="mb-b2b__inner">
    <img class="mb-b2b__mark"
         src="{{ 'Cartedevizitare-removebg-preview.png' | asset_url }}"
         alt=""
         width="252"
         height="144"
         loading="lazy"
         decoding="async"
         aria-hidden="true">
    <p>
      Vous souhaitez offrir Maison Bonjour&nbsp;? Ou commander pour votre entreprise&nbsp;?
      <a href="{{ b2b_url }}">Nous &eacute;crire <span aria-hidden="true">&rarr;</span></a>
    </p>
  </div>
</aside>

<footer class="mb-footer" role="contentinfo">
  <div class="mb-footer__inner">
    <div class="mb-footer__cols">

      <section class="mb-footer__col mb-footer__col--brand">
        <a class="mb-footer__logo-link" href="{{ routes.root_url }}" aria-label="Maison Bonjour — Accueil">
          <img class="mb-footer__logo-img"
               src="{{ 'maison_bonjour_dark_v2-removebg-preview.png' | asset_url }}"
               alt="Maison Bonjour"
               width="440"
               height="252"
               loading="lazy"
               decoding="async">
        </a>
        <p class="mb-footer__tagline">
          L&rsquo;art de vivre fran&ccedil;ais, livr&eacute; chaque mois &agrave; Cluj-Napoca.
        </p>
        <div class="mb-footer__route" aria-label="De la France à la Roumanie">
          <span class="mb-footer__route-end">FR</span>
          <span class="mb-footer__route-line" aria-hidden="true"></span>
          <span class="mb-footer__route-end">RO</span>
        </div>
      </section>

      <section class="mb-footer__col mb-footer__col--cta">
        <span class="mb-footer__label">Pas encore pr&ecirc;te&nbsp;?</span>
        <p class="mb-footer__cta-title">Rejoindre Maison Bonjour.</p>
        <a class="btn btn--secondary mb-footer__btn" href="{{ subscribe_url }}">S&rsquo;abonner &agrave; la box</a>
      </section>

      <nav class="mb-footer__col mb-footer__col--links" aria-label="Liens pratiques">
        <div class="mb-footer__group">
          <span class="mb-footer__label">Aide</span>
          <ul class="mb-footer__links">
            <li><a href="{{ faq_url }}">FAQ</a></li>
            <li><a href="{{ contact_url }}">Contact</a></li>
            <li><a href="{{ magazine_url }}">Magazine</a></li>
          </ul>
        </div>
        <div class="mb-footer__group">
          <span class="mb-footer__label">L&eacute;gal</span>
          <ul class="mb-footer__links">
            <li><a href="{{ cgv_url }}">CGV</a></li>
            <li><a href="{{ privacy_url }}">Confidentialit&eacute;</a></li>
          </ul>
        </div>
      </nav>

    </div>

    <div class="mb-footer__bottom">
      <ul class="mb-footer__social" aria-label="R&eacute;seaux sociaux">
        {%- if instagram_url != blank -%}
          <li>
            <a href="{{ instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="4"/>
                <circle cx="12" cy="12" r="4"/>
                <circle cx="17.5" cy="6.5" r="0.6" fill="currentColor"/>
              </svg>
            </a>
          </li>
        {%- endif -%}
        {%- if tiktok_url != blank -%}
          <li>
            <a href="{{ tiktok_url }}" target="_blank" rel="noopener" aria-label="TikTok">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M14 4v9.5a3.5 3.5 0 1 1-3.5-3.5"/>
                <path d="M14 4c.5 2.5 2.5 4 5 4"/>
              </svg>
            </a>
          </li>
        {%- endif -%}
        {%- if facebook_url != blank -%}
          <li>
            <a href="{{ facebook_url }}" target="_blank" rel="noopener" aria-label="Facebook">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M14 8h2.5V5H14c-1.7 0-3 1.3-3 3v2H9v3h2v8h3v-8h2.5l.5-3H14V8z"/>
              </svg>
            </a>
          </li>
        {%- endif -%}
      </ul>

      <p class="mb-footer__copy">
        &copy; {{ year }} Maison Bonjour &middot; Made in France &middot; Livr&eacute; en Roumanie
      </p>
    </div>
  </div>
</footer>

{% stylesheet %}
  /* Bandeau B2B */
  .mb-b2b {
    background: var(--cream-warm);
    padding: 40px var(--container-padding);
  }
  .mb-b2b__inner {
    max-width: 700px;
    margin-inline: auto;
    text-align: center;
  }
  /* Logo en "sceau" / en-tête de papier — petit et discret, donne un effet
     papeterie au bandeau B2B. Version marine transparent sur le fond cream-warm. */
  .mb-b2b__mark {
    display: block;
    margin: 0 auto 18px;
    width: auto;
    height: auto;
    max-height: 72px;
    opacity: 0.92;
  }
  .mb-b2b p {
    font-family: var(--font-sans);
    font-style: italic;
    font-size: 15px;
    line-height: 1.65;
    color: var(--text-muted);
    margin: 0;
  }
  .mb-b2b a {
    color: var(--gold);
    transition: opacity 0.25s ease;
    white-space: nowrap;
  }
  .mb-b2b a:hover { opacity: 0.7; color: var(--gold); }

  /* Footer */
  .mb-footer {
    background: var(--marine);
    color: var(--text-cream);
    /* padding-bottom large : laisse respirer la signature (wordmark hero) en bas à gauche */
    padding: 88px var(--container-padding) 120px;
  }

  .mb-footer__inner {
    max-width: 1200px;
    margin-inline: auto;
  }

  .mb-footer__cols {
    display: grid;
    grid-template-columns: 1.1fr 1fr 0.9fr;
    gap: clamp(40px, 6vw, 88px);
    align-items: start;
  }

  .mb-footer__col {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  /* Logo image — colonne brand footer. Version cream sur marine pour matcher le fond.
     Hauteur respirée (le footer a la place) ; respecte les proportions du logo. */
  .mb-footer__logo-link {
    display: inline-block;
    line-height: 0;
    transition: opacity 0.3s ease;
  }
  .mb-footer__logo-link:hover { opacity: 0.85; }
  .mb-footer__logo-img {
    display: block;
    width: auto;
    height: auto;
    max-width: 240px;
  }

  .mb-footer__tagline {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 15px;
    line-height: 1.55;
    color: var(--gold-soft);
    max-width: 280px;
    margin: 0;
  }

  /* Ligne de trajet FR ···· RO */
  .mb-footer__route {
    display: flex;
    align-items: center;
    gap: 14px;
    max-width: 220px;
    margin-top: 8px;
    color: var(--gold);
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
  }
  .mb-footer__route-end { flex-shrink: 0; }
  .mb-footer__route-line {
    flex: 1;
    height: 1px;
    background-image: radial-gradient(circle, var(--gold) 0.9px, transparent 1px);
    background-size: 8px 1px;
    background-repeat: repeat-x;
    background-position: left center;
    opacity: 0.6;
  }

  .mb-footer__label {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .mb-footer__cta-title {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 22px;
    color: var(--text-cream);
    margin: 0;
    line-height: 1.2;
  }

  .mb-footer__btn {
    align-self: start;
    margin-top: 8px;
  }

  /* Deux groupes sémantiques (Aide / Légal) au lieu d'une longue liste mélangée */
  .mb-footer__group {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .mb-footer__col--links .mb-footer__label {
    margin-bottom: 4px;
  }

  .mb-footer__links {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .mb-footer__links a {
    font-family: var(--font-sans);
    font-size: 14px;
    color: rgba(250, 246, 236, 0.7);
    transition: color 0.25s ease;
  }
  .mb-footer__links a:hover { color: var(--text-cream); }

  /* Bottom row — contenu group é à droite, coin bas-gauche réservé à la signature */
  .mb-footer__bottom {
    margin-top: clamp(48px, 6vw, 80px);
    padding-top: 28px;
    border-top: 1px solid rgba(184, 150, 90, 0.2);
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 28px;
  }

  .mb-footer__social {
    display: flex;
    align-items: center;
    gap: 16px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .mb-footer__social a {
    display: inline-flex;
    color: rgba(250, 246, 236, 0.5);
    transition: opacity 0.25s ease, color 0.25s ease;
    line-height: 0;
  }
  .mb-footer__social a:hover {
    color: var(--text-cream);
    opacity: 1;
  }

  .mb-footer__copy {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(250, 246, 236, 0.5);
    margin: 0;
    text-align: right;
  }

  /* Mobile — plus compact : marque + abonnement pleine largeur, puis les deux
     groupes de liens côte à côte (au lieu d'une longue pile verticale). */
  @media (max-width: 767px) {
    .mb-footer { padding: 48px var(--container-padding); }
    .mb-footer__logo-img { max-width: 200px; }
    .mb-footer__cols {
      grid-template-columns: 1fr 1fr;
      gap: 36px 24px;
    }
    .mb-footer__col--brand,
    .mb-footer__col--cta {
      grid-column: 1 / -1;
    }
    .mb-footer__col--links {
      grid-column: 1 / -1;
      flex-direction: row;
      gap: 28px;
    }
    .mb-footer__group { flex: 1 1 0; }
    .mb-footer__bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
      margin-top: 40px;
    }
    .mb-footer__copy { text-align: left; }
    .mb-b2b { padding: 32px var(--container-padding); }
    .mb-b2b__mark { max-height: 56px; margin-bottom: 14px; }
    .mb-b2b p { font-size: 14px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "header",
      "content": "Liens principaux"
    },
    {
      "type": "url",
      "id": "subscribe_url",
      "label": "Lien — S'abonner"
    },
    {
      "type": "url",
      "id": "b2b_url",
      "label": "Lien — Cadeaux / B2B"
    },
    {
      "type": "header",
      "content": "Liens pratiques"
    },
    { "type": "url", "id": "faq_url",      "label": "FAQ" },
    { "type": "url", "id": "contact_url",  "label": "Contact" },
    { "type": "url", "id": "cgv_url",      "label": "CGV" },
    { "type": "url", "id": "privacy_url",  "label": "Confidentialité" },
    { "type": "url", "id": "magazine_url", "label": "Magazine" },
    {
      "type": "header",
      "content": "Réseaux sociaux"
    },
    { "type": "url", "id": "instagram_url", "label": "Instagram" },
    { "type": "url", "id": "tiktok_url",    "label": "TikTok" },
    { "type": "url", "id": "facebook_url",  "label": "Facebook" }
  ]
}
{% endschema %}
