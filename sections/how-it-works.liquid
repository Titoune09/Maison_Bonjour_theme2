{%- liquid
  assign title = section.settings.title | default: 'Trois engagements. Une seule promesse : le 15 du mois.'
  assign lead  = section.settings.lead  | default: 'Vous choisissez la durée. Nous nous occupons du reste — un objet, un carnet, un tampon, douze mois durant.'

  assign use_defaults = false
  if section.blocks.size == 0
    assign use_defaults = true
  endif
-%}

<section class="engage section--warm section--immersive" aria-label="Nos engagements">
  <div class="container">

    <header class="engage__intro reveal">
      <h2 class="engage__title" data-split-words>{{ title }}</h2>
      <p class="engage__lead">{{ lead }}</p>
    </header>

    <ol class="engage__list" role="list">
      {%- if use_defaults -%}
        {%- comment -%} Contenu par défaut : les blocks de preset ne sont pas instanciés
            quand la section est appelée via {% section %} dans un template .liquid. {%- endcomment -%}
        <li class="engage__item reveal reveal--delay-0">
          <span class="engage__num" aria-hidden="true">I</span>
          <h3 class="engage__name">La ponctualité</h3>
          <p class="engage__text">Le 15 de chaque mois, sans exception. Livrée chez vous à Cluj-Napoca, frais de livraison inclus.</p>
        </li>
        <li class="engage__item reveal reveal--delay-1">
          <span class="engage__num" aria-hidden="true">II</span>
          <h3 class="engage__name">La liberté</h3>
          <p class="engage__text">Aucune durée imposée. Vous mettez en pause ou vous résiliez en un clic, quand vous le souhaitez.</p>
        </li>
        <li class="engage__item reveal reveal--delay-2">
          <span class="engage__num" aria-hidden="true">III</span>
          <h3 class="engage__name">La transparence</h3>
          <p class="engage__text">Le prix annoncé est le prix payé. Pas de frais cachés, jamais — c’est notre seule règle.</p>
        </li>
      {%- else -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'engagement' -%}
            <li class="engage__item reveal reveal--delay-{{ forloop.index0 }}" {{ block.shopify_attributes }}>
              <span class="engage__num" aria-hidden="true">{{ block.settings.roman | default: forloop.index }}</span>
              <h3 class="engage__name">{{ block.settings.name }}</h3>
              {%- if block.settings.text != blank -%}
                <p class="engage__text">{{ block.settings.text }}</p>
              {%- endif -%}
            </li>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </ol>

  </div>
</section>

{% stylesheet %}
  .engage { padding-block: clamp(80px, 10vw, 140px); }

  .engage__intro {
    max-width: 760px;
    margin: 0 auto clamp(56px, 6vw, 96px);
    text-align: center;
  }
  .engage__title {
    margin: 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.75rem, 2.4vw + 1rem, 3rem);
    line-height: 1.15;
    letter-spacing: -0.005em;
    color: var(--marine);
  }
  .engage__lead {
    margin: 22px auto 0;
    max-width: 52ch;
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 16px;
    line-height: 1.7;
    color: var(--text);
  }

  /* ----- LISTE ÉDITORIALE DES ENGAGEMENTS ----- */
  .engage__list {
    list-style: none;
    margin: 0 auto;
    padding: 0;
    max-width: 1080px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  .engage__item {
    padding: clamp(28px, 3vw, 40px) 0;
    border-top: 1px solid rgba(184, 150, 90, 0.28);
  }
  .engage__item:last-child {
    border-bottom: 1px solid rgba(184, 150, 90, 0.28);
  }

  .engage__num {
    display: block;
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.6rem, 1vw + 1.1rem, 2.1rem);
    line-height: 1;
    color: var(--gold);
    margin-bottom: 16px;
  }
  .engage__name {
    margin: 0;
    font-family: var(--font-serif);
    font-style: normal;
    font-weight: 400;
    font-size: clamp(1.35rem, 1vw + 0.9rem, 1.75rem);
    line-height: 1.15;
    color: var(--marine);
    letter-spacing: -0.005em;
  }
  .engage__text {
    margin: 14px 0 0;
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 15px;
    line-height: 1.7;
    color: var(--text);
    max-width: 42ch;
  }

  /* ----- DESKTOP : 3 colonnes, filets verticaux or ----- */
  @media (min-width: 768px) {
    .engage__list {
      grid-template-columns: repeat(3, 1fr);
      gap: clamp(32px, 4vw, 64px);
      border-top: 1px solid rgba(184, 150, 90, 0.28);
    }
    .engage__item {
      border-top: 0;
      border-bottom: 0;
      padding: clamp(32px, 3vw, 48px) 0 0;
      position: relative;
    }
    .engage__item:last-child { border-bottom: 0; }
    /* filet vertical entre les colonnes */
    .engage__item + .engage__item::before {
      content: "";
      position: absolute;
      top: clamp(32px, 3vw, 48px);
      left: calc(clamp(32px, 4vw, 64px) / -2);
      width: 1px;
      height: 100%;
      background: rgba(184, 150, 90, 0.22);
    }
  }

  @media (max-width: 767px) {
    .engage { padding-block: 64px; }
    .engage__intro { margin-bottom: 44px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "08 — Nos engagements",
  "settings": [
    { "type": "text", "id": "title", "label": "Titre", "default": "Trois engagements. Une seule promesse : le 15 du mois." },
    { "type": "textarea", "id": "lead", "label": "Phrase d’introduction", "default": "Vous choisissez la durée. Nous nous occupons du reste — un objet, un carnet, un tampon, douze mois durant." }
  ],
  "blocks": [
    {
      "type": "engagement",
      "name": "Engagement",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "roman", "label": "Numéro (ex : I, II, III)" },
        { "type": "text", "id": "name", "label": "Titre de l’engagement" },
        { "type": "textarea", "id": "text", "label": "Description" }
      ]
    }
  ],
  "presets": [
    {
      "name": "08 — Nos engagements",
      "blocks": [
        { "type": "engagement", "settings": { "roman": "I",   "name": "La ponctualité", "text": "Le 15 de chaque mois, sans exception. Livrée chez vous à Cluj-Napoca, frais de livraison inclus." } },
        { "type": "engagement", "settings": { "roman": "II",  "name": "La liberté", "text": "Aucune durée imposée. Vous mettez en pause ou vous résiliez en un clic, quand vous le souhaitez." } },
        { "type": "engagement", "settings": { "roman": "III", "name": "La transparence", "text": "Le prix annoncé est le prix payé. Pas de frais cachés, jamais — c’est notre seule règle." } }
      ]
    }
  ]
}
{% endschema %}
